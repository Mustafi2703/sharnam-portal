generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("office")
  portal       String   @default("office")
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships          ProjectMember[]
  uploadedDrawings     DrawingRevision[] @relation("DrawingUploader")
  checklistSubmissions ChecklistSubmission[]
  dailyLogsCreated     DailyLog[]        @relation("DailyLogCreator")
  auditEvents          AuditEvent[]
  meetingItems         MeetingItem[]
  leadsOwned           Lead[]
  attendance           Attendance[]
  leaveRequests        LeaveRequest[]
  rfisCreated          Rfi[]             @relation("RfiCreator")
  rfisAssigned         Rfi[]             @relation("RfiAssignee")
  rfiResponses         RfiResponse[]
  inspectionsCreated   QualityInspection[] @relation("InspectionCreator")
  inspectionsAssigned  QualityInspection[] @relation("InspectionAssignee")
  safetyReported       SafetyRecord[]      @relation("SafetyReporter")
  safetyAssigned       SafetyRecord[]      @relation("SafetyAssignee")
}

model RoleDefinition {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  portal      String
  permissions String
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  clientName  String?
  /// Client / stakeholder card (CRM → project)
  clientContactName String?
  clientEmail       String?
  clientPhone       String?
  clientAddress     String?
  clientGst         String?
  designConsultant  String?
  contractorName    String?
  location    String?
  status      String   @default("Planning")
  startDate   DateTime?
  endDate     DateTime?
  /// Comma-separated notification emails for this project
  notificationEmails String?
  emailFromName      String?  @default("शरणम् Portal")
  emailEnabled       Boolean  @default(true)
  notifyOnDrawingPublish Boolean @default(true)
  notifyOnChecklistSubmit Boolean @default(true)
  /// Outlook / Microsoft 365 mailbox for project mail (Graph when configured)
  outlookMailbox     String?
  outlookConnected   Boolean  @default(false)
  outlookConnectedAt DateTime?
  /// JSON array of enabled module keys (drawings, quality, safety, progress, …)
  enabledModules     String   @default("[\"drawings\",\"quality\",\"safety\",\"progress\",\"comms\",\"field\",\"cost\",\"reports\"]")
  /// JSON array of work packages e.g. Civil, PEB, Electrical
  workPackages       String   @default("[\"Civil\",\"PEB\"]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members              ProjectMember[]
  drawings             Drawing[]
  folders              DocumentFolder[]
  checklistAssignments ChecklistAssignment[]
  dailyLogs            DailyLog[]
  commMatrix           CommunicationMatrix[]
  commLogs             CommunicationLog[]
  meetings             Meeting[]
  budgetLines          CostBudgetLine[]
  monitoringLines      CostMonitoringLine[]
  cashflowPeriods      CostCashflowPeriod[]
  boqBatches           BoqImportBatch[]
  rateDiffs            CostRateDifference[]
  mbLines              CostMbLine[]
  bbsLines             CostBbsLine[]
  leads                Lead[]
  deals                Deal[]
  vendors              ProjectVendor[]
  rfis                 Rfi[]
  inspections          QualityInspection[]
  photos               ProjectPhoto[]
  submittals           Submittal[]
  coordinationIssues   DesignCoordinationIssue[]
  safetyRecords        SafetyRecord[]
  emailOutbox          EmailOutbox[]
  vendorBills          VendorBill[]
  communicationContacts CommunicationContact[]
  milestones           ProgressMilestone[]
  hindrances           ProgressHindrance[]
  risks                ProgressRisk[]
  plannedActual        ProgressPlannedActual[]
  legalApprovals       ProgressLegalApproval[]
  manpowerRows         ProgressManpower[]
  activityLines        ProgressActivityLine[]
  sorStats             ProgressSorStat[]
  qapActivities        QapActivity[]
  cubeTests            CubeTest[]
  qualityNcrs          QualityNcr[]
}

/** Mock / queued outbound emails (swap to SMTP/Graph later) */
model EmailOutbox {
  id        String   @id @default(cuid())
  projectId String?
  toEmails  String
  subject   String
  body      String
  context   String?
  status    String   @default("Queued")
  createdById String?
  createdAt DateTime @default(now())
  sentAt    DateTime?

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model DocumentFolder {
  id           String   @id @default(cuid())
  projectId    String
  path         String
  name         String
  parentPath   String?
  mockDriveId  String?
  lastSyncedAt DateTime?
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
}

model Drawing {
  id             String   @id @default(cuid())
  projectId      String
  drawingNumber  String
  title          String
  discipline     String   @default("Architecture")
  buildingArea   String?
  tlNo           String?
  currentRev     String   @default("R0")
  status         String   @default("Draft")
  isPublished    Boolean  @default(false)
  folderPath     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisions DrawingRevision[]
  submissions ChecklistSubmission[]
  rfis      Rfi[]
  inspections QualityInspection[]

  @@unique([projectId, drawingNumber])
}

model DrawingRevision {
  id             String   @id @default(cuid())
  drawingId      String
  revisionNumber String
  revisionLabel  String?
  fileUrl        String
  fileName       String?
  published      Boolean  @default(false)
  /// Planned issue date (GFC register column)
  plannedDate    DateTime?
  /// Actual upload / issue date
  actualDate     DateTime?
  uploadedById   String?
  /// Pre-upload drawing check submission that unlocked this revision
  preCheckSubmissionId String?
  createdAt      DateTime @default(now())

  drawing     Drawing @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  uploadedBy  User?   @relation("DrawingUploader", fields: [uploadedById], references: [id])
  checklistFills ChecklistSubmission[]
}

model ChecklistTemplate {
  id            String   @id @default(cuid())
  name          String
  category      String
  /// DrawingCheck | SiteExecution | QualityInspection | Safety
  checklistType String   @default("SiteExecution")
  source        String?
  /// QA / fill instructions shown on the form
  instructions  String?
  /// Minimum photos required on submit (Quality/Safety typically 3)
  requirePhotosMin Int   @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  items       ChecklistItem[]
  assignments ChecklistAssignment[]
}

model ChecklistItem {
  id           String  @id @default(cuid())
  templateId   String
  itemCode     String?
  description  String
  /// Per-line quality / safety instruction
  instruction  String?
  sortOrder    Int     @default(0)
  section      String?
  requirePhoto Boolean @default(false)

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ChecklistAssignment {
  id         String   @id @default(cuid())
  projectId  String
  templateId String
  status     String   @default("Assigned")
  assignedAt DateTime @default(now())

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  submissions ChecklistSubmission[]

  @@unique([projectId, templateId])
}

model ChecklistSubmission {
  id           String   @id @default(cuid())
  assignmentId String
  drawingId    String?
  revisionId   String?
  revisionNumber String?
  submittedById String
  status       String   @default("Draft")
  responsesJson String
  remarks      String?
  /// Fill | PreUploadDrawing
  purpose      String   @default("Fill")
  /// One-time token consumed when drawing/revision upload succeeds
  unlockToken  String?  @unique
  unlockUsedAt DateTime?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment  ChecklistAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  drawing     Drawing?            @relation(fields: [drawingId], references: [id])
  revision    DrawingRevision?    @relation(fields: [revisionId], references: [id])
  submittedBy User                @relation(fields: [submittedById], references: [id])
  photos      ChecklistPhoto[]
}

model ChecklistPhoto {
  id           String   @id @default(cuid())
  submissionId String
  /// Checklist template item this evidence belongs to (null = whole submission)
  itemId       String?
  /// photo | doc
  kind         String   @default("photo")
  fileUrl      String
  caption      String?
  comment      String?
  createdAt    DateTime @default(now())

  submission ChecklistSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model DailyLog {
  id               String   @id @default(cuid())
  projectId        String
  logDate          DateTime
  weatherCondition String?
  weatherSource    String?
  status           String   @default("Open")
  createdById      String
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project   Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User                 @relation("DailyLogCreator", fields: [createdById], references: [id])
  manpower  DailyLogManpower[]
  equipment DailyLogEquipment[]
  notes     DailyLogNote[]
  photos    DailyLogPhoto[]

  @@unique([projectId, logDate])
}

model DailyLogManpower {
  id          String  @id @default(cuid())
  dailyLogId  String
  companyName String
  workerCount Int
  hoursWorked Float   @default(8)
  comments    String?

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
}

model DailyLogEquipment {
  id            String  @id @default(cuid())
  dailyLogId    String
  companyName   String
  equipmentType String
  hoursUsed     Float?
  comments      String?

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
}

model DailyLogNote {
  id         String   @id @default(cuid())
  dailyLogId String
  noteText   String
  createdAt  DateTime @default(now())

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
}

model DailyLogPhoto {
  id         String   @id @default(cuid())
  dailyLogId String
  fileUrl    String
  caption    String?
  createdAt  DateTime @default(now())

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
}

model CommunicationMatrix {
  id                String   @id @default(cuid())
  projectId         String
  communicationType String
  fromRole          String
  toRole            String
  frequency         String
  channel           String   @default("Email")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/** BPCL-style contact matrix (TECHNICAL / COMMERCIAL) — Name, Designation, Company, SPOC, Mobile, Email, TO/CC */
model CommunicationContact {
  id             String   @id @default(cuid())
  projectId      String
  /// TECHNICAL | COMMERCIAL
  matrixKind     String   @default("TECHNICAL")
  /// Client | PMC | Consultant | Contractor | Other
  orgSection     String
  orgName        String
  /// true = section header row (org name only)
  isSectionHeader Boolean @default(false)
  sortOrder      Int      @default(0)
  personName     String?
  designation    String?
  company        String?
  spoc           String?
  mobile         String?
  email          String?
  /// TO | CC
  mailRole       String?
  officeAddress  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, matrixKind])
}

model CommunicationLog {
  id        String   @id @default(cuid())
  projectId String
  subject   String
  body      String?
  fromUser  String?
  toRoles   String
  channel   String   @default("In-App")
  sentAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Meeting {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  meetingDate DateTime
  location    String?
  /// Agenda → MoM → Follow-up → Closed (client video flow)
  status      String   @default("Agenda")
  /// Optional link to parent MoM when this is a follow-up
  parentMeetingId String?
  agendaNotes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   MeetingItem[]
}

model MeetingItem {
  id               String   @id @default(cuid())
  meetingId        String
  /// Agenda | MoM | Action | Follow-up
  category         String   @default("Agenda")
  description      String
  assignedToId     String?
  dueDate          DateTime?
  priority         String   @default("Medium")
  resolutionStatus String   @default("Open")
  carriedOverFrom  String?

  meeting    Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation(fields: [assignedToId], references: [id])
}

/// COP / RA bill tracker — vendor bill entries (client video)
model VendorBill {
  id            String   @id @default(cuid())
  projectId     String
  vendorId      String?
  vendorName    String
  billNo        String
  billDate      DateTime @default(now())
  amount        Float    @default(0)
  gstAmount     Float    @default(0)
  /// Draft | Submitted | Under review | Certified | Paid | Rejected
  status        String   @default("Draft")
  copNo         String?
  description   String?
  attachmentUrl String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor  Vendor? @relation(fields: [vendorId], references: [id])
}

model CostBudgetLine {
  id              String   @id @default(cuid())
  projectId       String
  srNo            String?
  description     String
  stakeholder     String?
  budgetedAmount  Float    @default(0)
  workOrderAmount Float    @default(0)
  certifiedAmount Float    @default(0)
  forecastedAmount Float   @default(0)
  nonTendered     Float    @default(0)
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CostMonitoringLine {
  id             String   @id @default(cuid())
  projectId      String
  packageName    String   @default("Civil")
  itemNo         String?
  description    String
  uom            String?
  rate           Float    @default(0)
  boqQty         Float    @default(0)
  extraQty       Float    @default(0)
  gfcQty         Float    @default(0)
  achievedQty    Float    @default(0)
  certifiedQty   Float    @default(0)
  excessQty      Float    @default(0)
  savingQty      Float    @default(0)
  boqCost        Float    @default(0)
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/** Measurement book line (from SPDC Budget * MB sheets) */
model CostMbLine {
  id          String   @id @default(cuid())
  projectId   String
  packageName String   @default("Civil")
  srNo        String?
  description String
  nos1        Float    @default(0)
  nos2        Float    @default(0)
  length      Float    @default(0)
  width       Float    @default(0)
  height      Float    @default(0)
  qty         Float    @default(0)
  unit        String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/** Bar bending schedule line (from * BBS sheets) */
model CostBbsLine {
  id          String   @id @default(cuid())
  projectId   String
  packageName String   @default("Civil")
  barMark     String?
  diameterMm  Float    @default(0)
  shape       String?
  lengthMm    Float    @default(0)
  nos         Float    @default(0)
  totalLength Float    @default(0)
  weightKg    Float    @default(0)
  location    String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CostCashflowPeriod {
  id               String   @id @default(cuid())
  projectId        String
  periodLabel      String
  periodDate       DateTime?
  packageName      String
  plannedAmount    Float    @default(0)
  actualAmount     Float    @default(0)
  progressPct      Float    @default(0)
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CostRateDifference {
  id                 String   @id @default(cuid())
  projectId          String
  materialType       String
  description        String
  vendorName         String?
  purchaseNo         String?
  qty                Float    @default(0)
  basicRate          Float    @default(0)
  purchaseRate       Float    @default(0)
  excessAmount       Float    @default(0)
  savingAmount       Float    @default(0)
  createdAt          DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BoqImportBatch {
  id           String   @id @default(cuid())
  projectId    String
  fileName     String
  rowCount     Int      @default(0)
  status       String   @default("Imported")
  summaryJson  String?
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   BoqItem[]
}

model BoqItem {
  id          String  @id @default(cuid())
  batchId     String
  srNo        String?
  description String
  section     String?
  qty         Float   @default(0)
  rate        Float   @default(0)
  unit        String?
  amount      Float   @default(0)
  costCode    String?
  rowKind     String  @default("item")

  batch BoqImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metaJson  String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Lead {
  id          String   @id @default(cuid())
  projectId   String?
  title       String
  contactName String?
  email       String?
  phone       String?
  stage       String   @default("New")
  value       Float?
  ownerId     String?
  createdAt   DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])
  owner   User?    @relation(fields: [ownerId], references: [id])
}

model Deal {
  id        String   @id @default(cuid())
  projectId String?
  name      String
  stage     String   @default("Negotiation")
  value     Float    @default(0)
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])
}

model EmployeeProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  empCode    String   @unique
  department String?
  designation String?
  joinDate   DateTime?
  createdAt  DateTime @default(now())
}

model Attendance {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime
  status     String   @default("Present")
  checkIn    String?
  checkOut   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model LeaveRequest {
  id        String   @id @default(cuid())
  userId    String
  fromDate  DateTime
  toDate    DateTime
  reason    String?
  status    String   @default("Pending")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// —— Procore-style directory, RFI, QA ——

model Vendor {
  id                  String   @id @default(cuid())
  name                String
  /// Contractor | Vendor | Client | Consultant | PMC
  partyType           String   @default("Vendor")
  trade               String?
  address             String?
  city                String?
  state               String?
  country             String?  @default("India")
  businessPhone       String?
  email               String?
  website             String?
  primaryContactName  String?
  licenseNumber       String?
  gstNumber           String?
  isUnionMember       Boolean  @default(false)
  isPrequalified      Boolean  @default(false)
  isMinorityOwned     Boolean  @default(false)
  isWomenOwned        Boolean  @default(false)
  insuranceVerified   Boolean  @default(false)
  notes               String?
  createdVia          String   @default("Manual")
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt

  projects ProjectVendor[]
  rfis     Rfi[]
  bills    VendorBill[]
}

model ProjectVendor {
  id         String   @id @default(cuid())
  projectId  String
  vendorId   String
  tradeRole  String?
  assignedVia String  @default("Manual")
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([projectId, vendorId])
}

model Rfi {
  id                    String    @id @default(cuid())
  projectId             String
  number                String
  subject               String
  question              String
  /// RequestForInformation | DrawingChecklist | QualityInspection | Manual | ClientConcern
  rfiKind               String    @default("RequestForInformation")
  status                String    @default("Open")
  ballInCourt           String    @default("Assignee")
  assignedToId          String?
  createdById           String
  dueDate               DateTime?
  closedAt              DateTime?
  linkedDrawingId       String?
  drawingPinJson        String?
  /// Legacy: often stores checklist template id
  linkedChecklistItemId String?
  /// Checklist assignment to be filled by matrix parties / vendor
  linkedAssignmentId    String?
  specSectionLink       String?
  responsibleVendorId   String?
  questionReceivedFrom  String?
  distributionJson      String?
  scheduleImpact        String?   @default("None")
  costImpact            String?   @default("None")
  isPrivate             Boolean   @default(false)
  attachmentsJson       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User?        @relation("RfiAssignee", fields: [assignedToId], references: [id])
  createdBy  User         @relation("RfiCreator", fields: [createdById], references: [id])
  drawing    Drawing?     @relation(fields: [linkedDrawingId], references: [id])
  vendor     Vendor?      @relation(fields: [responsibleVendorId], references: [id])
  responses  RfiResponse[]

  @@unique([projectId, number])
}

model RfiResponse {
  id                 String   @id @default(cuid())
  rfiId              String
  respondedById      String
  responseChannel    String   @default("Web")
  responseText       String
  isOfficialResponse Boolean  @default(false)
  createdAt          DateTime @default(now())

  rfi         Rfi  @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  respondedBy User @relation(fields: [respondedById], references: [id])
}

model QualityInspection {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  inspectionType String  @default("Quality")
  /// Draft → Ready → In Progress → Closed
  status        String   @default("Draft")
  location      String?
  linkedDrawingId String?
  /// Checklist template that seeded the form items
  checklistTemplateId String?
  trade         String?
  createdById   String
  assignedToId  String?
  dueDate       DateTime?
  completedAt   DateTime?
  attachmentsJson String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  drawing    Drawing? @relation(fields: [linkedDrawingId], references: [id])
  createdBy  User    @relation("InspectionCreator", fields: [createdById], references: [id])
  assignedTo User?   @relation("InspectionAssignee", fields: [assignedToId], references: [id])
  items      InspectionItem[]
}

model InspectionItem {
  id            String  @id @default(cuid())
  inspectionId  String
  description   String
  status        String  @default("Pending")
  remarks       String?
  /// JSON array of { url, name, kind, comment? }
  attachmentsJson String?
  sortOrder     Int     @default(0)
  dueDate       DateTime?
  autoGenerateRfi Boolean @default(false)
  linkedRfiId   String?

  inspection QualityInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

model ProjectPhoto {
  id          String   @id @default(cuid())
  projectId   String
  fileUrl     String
  album       String   @default("Unclassified")
  description String?
  trade       String?
  location    String?
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Submittal {
  id          String   @id @default(cuid())
  projectId   String
  number      String
  title       String
  submittalType String @default("Product Data")
  /// Draft → Submitted → Under Review → Revise & Resubmit → Approved / Rejected
  status      String   @default("Draft")
  ballInCourt String   @default("Submitter")
  specSection String?
  description String?
  revisionNumber String @default("0")
  reviewerNotes String?
  attachmentsJson String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
}

model DesignCoordinationIssue {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
